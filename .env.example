# Copy to .env locally if helpful; on Render/Fly/Railway set vars in the dashboard instead.

# --- Phase 1: same origin (Express serves client/dist) ---
# SERVE_CLIENT=1 is required for the server to serve the Vite build.
SERVE_CLIENT=1

# Browser origin for CORS + Socket.io (must match the URL players type in the address bar).
# Leave unset on Render to auto-use https://<your-service>.onrender.com from RENDER_EXTERNAL_URL.
# CLIENT_ORIGIN=https://your-app.onrender.com

# Port (Render and most hosts inject PORT automatically).
# PORT=3001

# --- Split-origin only (Phase 2): build the client with API URL baked in ---
# VITE_SERVER_URL=https://your-api.example.com
