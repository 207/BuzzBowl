# Local dev: point the SPA at the game server (default in code is http://localhost:3001).
VITE_SERVER_URL=http://localhost:3001

# Phase 1 production (single host): omit VITE_SERVER_URL so the client uses the same origin as the page.
# Phase 2 (UI on Vercel, API elsewhere): set at build time, e.g. VITE_SERVER_URL=https://api.example.com
